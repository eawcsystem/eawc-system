# Ignoriere Umgebungsvariablen-Dateien
.env

# Ignoriere das node_modules-Verzeichnis
node_modules/

# Ignoriere Protokolldateien
*.log

git add .gitignore
git commit -m "Add .gitignore to ignore sensitive files"
git push origin main

git rm --cached .env
git commit -m "Remove .env from the repository"
git push origin main
